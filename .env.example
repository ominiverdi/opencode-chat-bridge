# OpenCode Chat Bridge Configuration
# Copy this file to .env and fill in your values

# ===================
# Matrix Connector
# ===================
# See docs/MATRIX_SETUP.md for detailed instructions

# Matrix homeserver URL
MATRIX_HOMESERVER=https://matrix.org

# Bot access token (get from Element: Settings > Help & About > Access Token)
MATRIX_ACCESS_TOKEN=syt_your_access_token_here

# Bot user ID (e.g., @mybot:matrix.org)
MATRIX_USER_ID=@your-bot-username:matrix.org

# Bot password (RECOMMENDED - tokens won't expire)
# If set, the bot will login with password and auto-refresh tokens
MATRIX_PASSWORD=your_matrix_password

# Restrict bot access to specific Matrix user IDs (comma-separated, optional)
# MATRIX_ALLOWED_USERS=@alice:matrix.org,@bob:matrix.org

# ===================
# Slack Connector
# ===================
# See docs/SLACK_SETUP.md for detailed instructions

# Bot Token: api.slack.com/apps > Your App > OAuth & Permissions
# Starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App Token: api.slack.com/apps > Your App > Basic Information > App-Level Tokens
# Needs connections:write scope, starts with xapp-
SLACK_APP_TOKEN=xapp-your-app-token-here

# Restrict bot access to specific Slack user IDs (comma-separated, optional)
# SLACK_ALLOWED_USERS=U01ABC123,U02DEF456

# ===================
# Mattermost Connector
# ===================
# See docs/MATTERMOST_SETUP.md for detailed instructions

# Mattermost server URL
MATTERMOST_URL=https://mattermost.example.com

# Bot access token (from Integrations > Bot Accounts)
MATTERMOST_TOKEN=your_bot_access_token

# Team name/slug (optional -- auto-detected if bot is in one team)
# MATTERMOST_TEAM=myteam

# Restrict bot access to specific Mattermost user IDs (comma-separated, optional)
# MATTERMOST_ALLOWED_USERS=user-id-1,user-id-2

# ===================
# Common Settings
# ===================

# Trigger prefix for bot commands (default: !oc)
# Users type: !oc what time is it?
# Each connector can override with its own env var:
# SLACK_TRIGGER=!oc
# DISCORD_TRIGGER=!oc
# MATRIX_TRIGGER=!oc
# MATTERMOST_TRIGGER=!oc
# WHATSAPP_TRIGGER=!oc

# Session retention period in days (default: 7)
# Sessions older than this are cleaned up on connector startup
# SESSION_RETENTION_DAYS=7

# Session retention period in minutes (default: 30 for Slack, unset for others)
# Stale in-memory sessions are expired by a background sweep based on inactivity
# SESSION_RETENTION_MINS=30

# Session storage directory (default: ~/.cache/opencode-chat-bridge/sessions)
# IMPORTANT: Must be OUTSIDE any git repo to avoid cluttering dev sessions
# SESSION_BASE_DIR=/path/to/sessions

# ===================
# Discord Connector
# ===================
# See docs/DISCORD_SETUP.md for detailed instructions

# Bot token: discord.com/developers > Your App > Bot > Token
DISCORD_TOKEN=your_discord_bot_token

# Restrict bot access to specific Discord user IDs (comma-separated, optional)
# DISCORD_ALLOWED_USERS=123456789012345678,234567890123456789

# ===================
# WhatsApp Connector
# ===================
# See docs/WHATSAPP_SETUP.md for detailed instructions
# QR code auth is required on first run; trigger and allowlist are optional
# WHATSAPP_ALLOWED_USERS=34600111222,34600333444
# Auth data stored in WHATSAPP_AUTH_DIR (default: .whatsapp-auth/)

# ===================
# Future Connectors
# ===================

# IRC
# IRC_SERVER=irc.libera.chat
# IRC_NICK=oc-bot
# IRC_PASSWORD=your_password

# ===================
# Web Connector
# ===================
# Embeddable chat widget -- no platform account needed

# Server port (default: 3420)
# WEB_PORT=3420

# Bind address (default: 0.0.0.0)
# WEB_HOST=0.0.0.0

# Allowed origins for CORS, comma-separated (default: * = all)
# WEB_ALLOWED_ORIGINS=https://example.com,https://app.example.com

# Public URL override (when behind a reverse proxy)
# WEB_PUBLIC_URL=https://chat.example.com
